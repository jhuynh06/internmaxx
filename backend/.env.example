# Copy to .env and fill in. Load before running: `set -a; . ./.env; set +a`
# (.env is gitignored — never commit real secrets.)

# Discord webhook (required to actually send alerts). Rotate the old hardcoded
# one that was committed in git history. Split a webhook URL of the form
# https://discord.com/api/webhooks/<ID>/<SECRET> into these two values:
DISCORD_WEBHOOK_ID=
DISCORD_WEBHOOK_SECRET=

# SQLite path (dedup + seeding state). Keep this file across restarts —
# deleting it re-seeds and suppresses one cycle of alerts.
DB_PATH=internmaxx.db

# Poll intervals per tier (Go duration syntax: 5m, 15m, 1h). Conservative
# defaults; once you've confirmed no 429s you can push tier 1 + aggregators
# toward the aggressive floor (TIER1_INTERVAL=2m, AGG_INTERVAL=3m).
TIER1_INTERVAL=5m
TIER2_INTERVAL=15m
TIER3_INTERVAL=60m
# Aggregator (Simplify/vanshb03) cadence, independent of the tiers. The 10MB+
# file is only re-downloaded when its GitHub commit changes, so polling often is
# cheap.
AGG_INTERVAL=5m

# Worker pool size and per-host politeness gap.
WORKERS=8
HOST_MIN_GAP=300ms

# Filtering.
US_ONLY=true
ALLOW_PHD=false
NOTIFY_CAP=25

# Optional run scoping (flags override these): groups/aliases, tiers, slugs.
# SCOPE_GROUPS=ai,quant
# SCOPE_TIERS=1,2
# SCOPE_ONLY=
# SCOPE_EXCLUDE=

# Optional dead-man's-switch URL pinged every minute (e.g. healthchecks.io).
# HEALTHCHECK_URL=

# Application-tracking HTTP API bind address. Localhost by default (no auth) —
# reach it via SSH tunnel. Set ":8080" only behind your own auth, or "" to disable.
API_ADDR=127.0.0.1:8080
